{
  "permissions": {
    "allow": [
      "Read", "Edit", "Write",
      "Bash(git *)", "Bash(npm *)", "Bash(npx *)",
      "Bash(date)", "Bash(ls *)", "Bash(cat *)", "Bash(mkdir *)"
    ],
    "ask": [],
    "deny": [
      "Read(.env)", "Read(**/secrets/**)",
      "Bash(rm -rf *)", "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo '$CLAUDE_TOOL_INPUT' | grep -qE 'rm -rf|git push.*--force'; then echo 'Заблокировано политикой проекта' && exit 2; fi"
          }
        ]
      }
    ]
  }
}